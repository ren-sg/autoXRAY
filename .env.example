# VPN-домен (аргумент для autoXRAY1.sh)
XRAY_DOMAIN=vpn.example.com

# Certbot (для доп. поддоменов в post-install)
CERTBOT_EMAIL=you@example.com

# WARP: 1 = как upstream, 0 = post-install patch routing warp→direct
USE_WARP=1

# Пути на сервере
NGINX_CUSTOM_DIR=/etc/nginx/conf.d/autoxray-custom
STATE_DIR=/etc/autoXRAY
